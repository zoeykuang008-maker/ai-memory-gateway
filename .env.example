# ============================================================
# AI Memory Gateway · 环境变量示例
# 复制本文件为 .env（本地）或在 Zeabur/Render 的 Variables 里逐项填。
# 占位值都不是真值——换成你自己的。
# ============================================================

# ---- 必填：LLM 转发 ----
API_KEY=sk-or-v1-你的OpenRouterKey
API_BASE_URL=https://openrouter.ai/api/v1/chat/completions
DEFAULT_MODEL=anthropic/claude-sonnet-4.5
PORT=8080

# ---- 鉴权（强烈建议设）：设了之后所有接口/面板都要带这个密钥 ----
# dashboard 访问：/dashboard?gateway_key=你设的值；客户端请求头 X-Gateway-Key: 你设的值
GATEWAY_SECRET=换成你自己的一串随机密码

# ---- 记忆系统（需要 PostgreSQL）----
DATABASE_URL=postgresql://user:password@host:5432/dbname
MEMORY_ENABLED=true
MEMORY_MODEL=anthropic/claude-haiku-4.5
MAX_MEMORIES_INJECT=15
MIN_SCORE_THRESHOLD=0.15
MEMORY_EXTRACT_INTERVAL=1
TIMEZONE_HOURS=8

# ---- 分区缓存（省 token，可选）----
CACHE_PARTITION_ENABLED=true
CACHE_PARTITION_X=15
CACHE_SUMMARY_MODEL=anthropic/claude-haiku-4.5
# PARTITION_SESSION_ID=my-thread

# ---- 个性化（全部可选；不填=通用，空白部署不含任何人名/暗号/健康红线）----
# USER_NAME=对话对象的名字
# AI_NAME=AI的自称名
# HOME_TITLE=OUR HOME
# HOME_SUBTITLE=
# SINCE_DATE=2026-01-01
# HEALTH_SAFETY_NOTE=（健康/用药护栏正文，随记忆注入；不填则不注入）
# INTIMACY_UNLOCK_KEYS=暗号一,暗号二
# IMAGE_ENABLED=false

# ---- 向量搜索（可选，语义检索）----
# MEMORY_VECTOR_ENABLED=false
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=256

# ---- 其他（可选）----
# FORCE_STREAM=false
# REASONING_EFFORT=
